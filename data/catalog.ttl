@prefix tdy: <https://tdytrading.example/parts#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tdy:build_1 a tdy:Build ;
    tdy:hasPart tdy:board_b560,
        tdy:case_atx,
        tdy:cpu_i7,
        tdy:gpu_mid,
        tdy:psu_750,
        tdy:ram_ddr4,
        tdy:ssd_m2 .

tdy:build_2 a tdy:Build ;
    tdy:hasPart tdy:board_b650,
        tdy:case_atx,
        tdy:cpu_r7,
        tdy:gpu_big,
        tdy:psu_450,
        tdy:ram_ddr5 .

tdy:case_matx a tdy:Case ;
    tdy:acceptsFormFactor "microATX" ;
    tdy:maxGpuMm 250 .

tdy:gpu_small a tdy:GPU ;
    tdy:draw 130 ;
    tdy:lengthMm 200 ;
    tdy:recommendedPsu 550 .

tdy:psu_1000 a tdy:PSU ;
    tdy:wattage 1000 .

tdy:ssd_sata a tdy:Storage ;
    tdy:interface "SATA" .

tdy:board_b560 a tdy:Motherboard ;
    tdy:formFactor "ATX" ;
    tdy:interface "M.2" ;
    tdy:ramGen "DDR4" ;
    tdy:socket "LGA1200" .

tdy:board_b650 a tdy:Motherboard ;
    tdy:formFactor "microATX" ;
    tdy:interface "M.2" ;
    tdy:ramGen "DDR5" ;
    tdy:socket "AM5" .

tdy:cpu_i7 a tdy:CPU ;
    tdy:draw 65 ;
    tdy:ramGen "DDR4" ;
    tdy:socket "LGA1200" .

tdy:cpu_r7 a tdy:CPU ;
    tdy:draw 105 ;
    tdy:ramGen "DDR5" ;
    tdy:socket "AM5" .

tdy:gpu_big a tdy:GPU ;
    tdy:draw 450 ;
    tdy:lengthMm 340 ;
    tdy:recommendedPsu 850 .

tdy:gpu_mid a tdy:GPU ;
    tdy:draw 220 ;
    tdy:lengthMm 285 ;
    tdy:recommendedPsu 650 .

tdy:psu_450 a tdy:PSU ;
    tdy:wattage 450 .

tdy:psu_750 a tdy:PSU ;
    tdy:wattage 750 .

tdy:ram_ddr4 a tdy:RAM ;
    tdy:ramGen "DDR4" .

tdy:ram_ddr5 a tdy:RAM ;
    tdy:ramGen "DDR5" .

tdy:ssd_m2 a tdy:Storage ;
    tdy:interface "M.2" .

tdy:case_atx a tdy:Case ;
    tdy:acceptsFormFactor "ATX",
        "microATX" ;
    tdy:maxGpuMm 360 .

